---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Premium Thermally Broken Aluminium Windows" currentPage="home">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <span class="hero-eyebrow">Central Coast · Sydney · Newcastle</span>
      <h1>Windows Built for<br /><em>Australian Homes</em></h1>
      <p class="hero-desc">Premium thermally broken aluminium windows — engineered to keep your home comfortable year-round while cutting energy costs. Supply and professional installation across the Central Coast, Sydney, and Newcastle.</p>
      <div class="btn-group">
        <a href="/contact" class="btn-primary">Get a Free Quote</a>
        <a href="/services" class="btn-outline">Our Services</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div>
          <div class="stat-number">15+</div>
          <div class="stat-label">Years Industry Experience</div>
        </div>
        <div>
          <div class="stat-number">3</div>
          <div class="stat-label">Regions Serviced</div>
        </div>
        <div>
          <div class="stat-number">100%</div>
          <div class="stat-label">Locally Owned & Operated</div>
        </div>
        <div>
          <div class="stat-number">A+</div>
          <div class="stat-label">Energy Performance</div>
        </div>
      </div>
    </div>
  </div>

  <!-- About intro -->
  <section>
    <div class="container">
      <div class="grid-2">
        <div>
          <p class="section-label">Who We Are</p>
          <h2 class="section-heading">Central Coast's Window Specialists</h2>
          <p class="section-sub">We're a locally owned window company based on the Central Coast of NSW, specialising in thermally broken aluminium windows for residential homes. From consultation through to professional installation, we manage every step of the process.</p>
          <br />
          <p class="section-sub">With over six years in the industry, we bring the knowledge, relationships, and craftsmanship that only comes from deep experience — not just showing up with a truck.</p>
          <br />
          <a href="/services" class="btn-primary" style="margin-top: 8px">See Our Services</a>
        </div>
        <div class="img-card">
          <img src="/who-we-are.jpg" alt="Window installer fitting aluminium windows" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Services overview -->
  <section>
    <div class="container">
      <p class="section-label">What We Do</p>
      <h2 class="section-heading">Our Services</h2>
      <p class="section-sub" style="margin-bottom: 48px">Everything you need, handled by one team who knows what they're doing.</p>

      <div class="grid-3">
        <div class="card">
          <div class="card-icon">🔥</div>
          <h3>Thermally Broken Windows</h3>
          <p>Our premium option for homeowners who want stronger thermal performance, better comfort year-round, and a cleaner high-end finish.</p>
        </div>
        <div class="card">
          <div class="card-icon">🪟</div>
          <h3>Standard Aluminium Windows</h3>
          <p>A dependable, cost-effective solution for renovations, investment properties, and homes where durability, appearance, and value all matter.</p>
        </div>
        <div class="card">
          <div class="card-icon">🏢</div>
          <h3>Commercial Windows</h3>
          <p>Practical aluminium window solutions for commercial and mixed-use projects, with support for specification, supply, and installation coordination.</p>
        </div>
      </div>

      <div style="text-align: center; margin-top: 40px">
        <a href="/services" class="btn-outline">Full Service Details →</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Why thermally broken -->
  <section>
    <div class="container">
      <div class="grid-2">
        <div class="img-card">
          <img src="https://images.unsplash.com/photo-1600607688969-a5bfcd646154?w=800&q=80" alt="Modern home with large windows" loading="lazy" />
        </div>
        <div>
          <p class="section-label">Why It Matters</p>
          <h2 class="section-heading">Not All Aluminium is Equal</h2>
          <p class="section-sub">Standard aluminium frames are highly conductive — they transfer heat and cold straight into your home. Thermally broken frames use a non-conductive polyamide barrier to break that transfer.</p>
          <br />
          <p class="section-sub">The result: warmer in winter, cooler in summer, less condensation, lower energy bills, and a quieter home.</p>
          <br />
          <a href="/science" class="btn-outline" style="margin-top: 8px">Learn the Science →</a>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Service area -->
  <section>
    <div class="container" style="text-align: center">
      <p class="section-label">Where We Work</p>
      <h2 class="section-heading">Servicing the NSW Coast</h2>
      <p class="section-sub" style="margin: 0 auto 48px">Based on the Central Coast, we service residential clients and builders across three regions.</p>

      <div class="grid-3">
        <div class="card" style="text-align: left">
          <div class="card-icon">📍</div>
          <h3>Central Coast</h3>
          <p>Our home base — from Gosford to Wyong and everything in between.</p>
        </div>
        <div class="card" style="text-align: left">
          <div class="card-icon">🌆</div>
          <h3>Sydney</h3>
          <p>Northern suburbs through to the wider metro area.</p>
        </div>
        <div class="card" style="text-align: left">
          <div class="card-icon">🏭</div>
          <h3>Newcastle</h3>
          <p>Hunter region and surrounds — residential and new builds.</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Product range -->
  <section>
    <div class="container">
      <p class="section-label">More Than One Option</p>
      <h2 class="section-heading">Window Solutions for Different Projects</h2>
      <p class="section-sub" style="margin-bottom: 48px">Not every job calls for the same system. We help you choose the right window solution based on budget, performance goals, and the type of project you're working on.</p>

      <div class="grid-3">
        <div class="card" style="text-align: left">
          <div class="card-icon">🏠</div>
          <h3>Residential Upgrades</h3>
          <p>From single-room replacements to full-home upgrades, we can recommend the right balance of performance, style, and budget for your home.</p>
        </div>
        <div class="card" style="text-align: left">
          <div class="card-icon">💼</div>
          <h3>Builder & Trade Support</h3>
          <p>Working on a renovation or new build? We can supply practical window solutions with straightforward communication and dependable coordination.</p>
        </div>
        <div class="card" style="text-align: left">
          <div class="card-icon">📍</div>
          <h3>Commercial Scope</h3>
          <p>We also support selected commercial projects across the Central Coast, Sydney, and Newcastle, including retail, hospitality, offices, and mixed-use work.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="cta-section">
    <p class="section-label">Ready to Get Started?</p>
    <h2 class="section-heading">Get a Free Quote Today</h2>
    <p class="section-sub">Tell us about your project and we'll point you toward the right solution, whether that's thermally broken, standard aluminium, or a commercial window package.</p>
    <div class="btn-group" style="justify-content: center">
      <a href="/contact" class="btn-primary">Contact Us</a>
      <a href="/services" class="btn-outline">View All Services</a>
    </div>
  </div>

</Layout>
