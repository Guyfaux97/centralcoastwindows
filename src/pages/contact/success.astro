---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Enquiry Received"
  description="Thanks for your enquiry — Central Coast Windows will be in touch shortly."
  currentPage=""
>
  <section style="min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 80px 24px;">
    <div style="max-width: 560px; margin: 0 auto;">
      <div style="font-size: 64px; margin-bottom: 24px;">🪟</div>
      <p class="section-label">Enquiry Received</p>
      <h1 class="section-heading" style="margin-bottom: 16px;">Thanks, we'll be in touch!</h1>
      <p class="section-sub" style="margin-bottom: 40px;">
        Your quote request has been sent to Todd at Central Coast Windows. We aim to respond within one business day — usually much faster.
      </p>
      <div class="btn-group" style="justify-content: center;">
        <a href="/" class="btn-primary">Back to Home</a>
        <a href="/services" class="btn-outline">Our Services</a>
      </div>
      <p style="margin-top: 48px; color: var(--text-muted); font-size: 14px;">
        Need to reach us sooner? Call <a href="tel:+61473149721" style="color: var(--accent)">0473 149 721</a>
      </p>
    </div>
  </section>
</Layout>
